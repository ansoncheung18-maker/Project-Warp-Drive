ax1.hist(monitor_new/1e9, bins=15, color='green', alpha=0.7, edgecolor='black')
ax1.axvline(x=REQUIRED_FREQ/1e9, color='r', linestyle='--', label='要求 (0.1 GHz)')
ax1.set_xlabel('監測頻率 (GHz)')
