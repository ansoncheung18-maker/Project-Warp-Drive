  - 反應時間: 0.05 μs → 0.0005 μs (0.5 ns)
"""

import matplotlib.pyplot as plt
import numpy as np
from datetime import datetime

print("=" * 70)
print("T-1.5：AI 控制系統反應速度模擬 (v2)")
print(f"執行日期: {datetime.now().strftime('%Y-%m-%d %H:%M')}")
