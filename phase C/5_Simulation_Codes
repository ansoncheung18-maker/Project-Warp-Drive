目標: 模擬曲率泡短距離航行 (1km → 1AU → 1光年)
      驗證曲率泡能夠實際移動
"""

import matplotlib.pyplot as plt
import numpy as np
from datetime import datetime

print("=" * 70)
print("T-4.2：短距離航行模擬")
print(f"執行日期: {datetime.now().strftime('%Y-%m-%d %H:%M')}")
print("=" * 70)

# ============================================================
# 參數設定
# ============================================================

print("\n[1] 航行參數:")
print("-" * 70)

# 距離 (米)
DISTANCES = {
    '1 km': 1e3,
    '10 km': 1e4,
    '100 km': 1e5,
    '1 AU': 1.496e11,
    '1 光年': 9.461e15,
}

# 速度 (c)
SPEED_C = 1500

# 光速 (m/s)
LIGHT_SPEED = 3e8

print(f"  航行速度: {SPEED_C} c")
print("  測試距離:")
for name, dist in DISTANCES.items():
    print(f"    {name}: {dist:.2e} m")

# ============================================================
# 計算航行時間
# ============================================================

print("\n[2] 航行時間計算:")
print("-" * 70)

def calculate_travel_time(distance_m, speed_c):
    """計算航行時間"""
    # 加速段 (假設加速到 1500c 需要 150 秒)
    accel_time = 150  # 秒
    accel_distance = 0.5 * (10 * LIGHT_SPEED) * accel_time**2  # 10 c/s 加速
    
    # 如果距離太短，只需要加速/減速
    if distance_m < 2 * accel_distance:
        # 未達到最高速度就開始減速
        max_speed = np.sqrt(distance_m * 10 * LIGHT_SPEED)  # 10 c/s 加速
        time = 2 * max_speed / (10 * LIGHT_SPEED)
        return time, '加速-減速'
    else:
        # 加速 + 巡航 + 減速
        cruise_distance = distance_m - 2 * accel_distance
        cruise_time = cruise_distance / (speed_c * LIGHT_SPEED)
        total_time = 2 * accel_time + cruise_time
        return total_time, '加速-巡航-減速'

print("| 距離 | 航行時間 | 模式 |")
print("|:---|:---|:---|")

for name, dist in DISTANCES.items():
    time, mode = calculate_travel_time(dist, SPEED_C)
    time_display = f"{time:.2e} 秒" if time > 1 else f"{time*1e3:.2f} 毫秒"
    if time > 3600:
        time_display = f"{time/3600:.2f} 小時"
    if time > 86400:
        time_display = f"{time/86400:.2f} 日"
    print(f"| {name} | {time_display} | {mode} |")

# ============================================================
# 模擬航行剖面
# ============================================================

print("\n[3] 航行剖面模擬 (1 AU):")
print("-" * 70)

# 模擬 1 AU 航行嘅速度剖面
distance_target = DISTANCES['1 AU']
time_steps = 5000
dt = 1  # 秒

speed_profile = []
distance_profile = []
time_profile = []

speed = 0
distance = 0
accel = 10 * LIGHT_SPEED  # 10 c/s
max_speed = SPEED_C * LIGHT_SPEED

for i in range(time_steps):
    t = i * dt
    
    # 加速到最高速度
    if speed < max_speed and distance < distance_target * 0.5:
        speed += accel * dt
        if speed > max_speed:
            speed = max_speed
    
    # 巡航
    # 檢查是否需要開始減速 (剩餘距離 < 減速距離)
    decel_distance = speed**2 / (2 * accel)
    remaining_distance = distance_target - distance
    
    if remaining_distance < decel_distance:
        speed -= accel * dt
        if speed < 0:
            speed = 0
    
    distance += speed * dt
    
    speed_profile.append(speed / LIGHT_SPEED)
    distance_profile.append(distance / 1.496e11)  # 轉換為 AU
    time_profile.append(t)

    if distance >= distance_target:
        break

print(f"  完成距離: {distance_profile[-1]*1.496e11:.2e} m ({distance_profile[-1]:.4f} AU)")
print(f"  所需時間: {time_profile[-1]:.0f} 秒 ({time_profile[-1]/3600:.2f} 小時)")
print(f"  最高速度: {max(speed_profile):.0f} c")

# ============================================================
# 結論
# ============================================================

print("\n" + "=" * 70)
print("🎯 結論")
print("=" * 70)

print(f"""
✅ 短距離航行模擬成功！

   1 AU 航行:
